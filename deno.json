{
  "lock": false,
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "deno.ns"],
    "types": ["lume/types.ts"],
    "jsx": "react-jsx",
    "jsxImportSource": "lume"
  },
  "unstable": ["temporal", "fmt-component"],
  "permissions": {
    "lume": {
      "read": true,
      "write": ["./"],
      "import": ["cdn.jsdelivr.net:443", "jsr.io:443", "deno.land:443", "esm.sh:443"],
      "net": [
        "0.0.0.0",
        "cdn.jsdelivr.net:443",
        "data.jsdelivr.com:443",
        "jsr.io:443",
        "deno.land:443",
        "esm.sh:443",
        "registry.npmjs.org:443",
        "fonts.googleapis.com:443",
        "fonts.gstatic.com:443"
      ],
      "env": true,
      "run": true,
      "ffi": true,
      "sys": true
    }
  },
  "lint": {
    "plugins": ["https://cdn.jsdelivr.net/gh/lumeland/lume@3.2.1/lint.ts"],
    "rules": {
      "exclude": ["no-import-prefix"]
    }
  },
  "fmt": {
    "lineWidth": 120
  },
  "imports": {
    "daisyui": "npm:daisyui@^5.5.19",
    "lume/": "https://cdn.jsdelivr.net/gh/lumeland/lume@3.2.1/",
    "lume/jsx-runtime": "https://cdn.jsdelivr.net/gh/oscarotero/ssx@0.1.14/jsx-runtime.ts",
    "stylelint-config-recess-order": "npm:stylelint-config-recess-order@^7.6.1",
    "stylelint-config-standard": "npm:stylelint-config-standard@^40.0.0",
    "stylelint-order": "npm:stylelint-order@^7.0.1"
  },
  "tasks": {
    "fmt:css": "deno run -A npm:stylelint \"**/*.css\" --fix",
    "fmt:watch": "deno fmt --watch .",
    "lume": {
      "description": "Run Lume command",
      "command": "deno run -P=lume lume/cli.ts"
    },
    "build": {
      "description": "Build the site for production",
      "command": "deno task lume",
      "dependencies": []
    },
    "serve": {
      "description": "Run and serve the site for development",
      "command": "deno task lume -s",
      "dependencies": []
    }
  }
}
