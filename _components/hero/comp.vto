<div class="hero">
  <div class="eyebrow-wrapper">
    <span class="eyebrow">{{ eyebrow }}</span>
  </div>
  <div class="title-wrapper">
    <h1 class="title">
      {{ title }}
    </h1>
  </div>
  <div class="subtitle-wrapper">
    <p class="subtitle">
      {{ subtitle }}
    </p>
  </div>
</div>
