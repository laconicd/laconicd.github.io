<svg
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
  viewBox="0 0 24 24"
  stroke="currentColor"
  stroke-width="{{ stroke || 2 }}"
  width="{{ (size || 5) * 0.25 }}rem"
  height="{{ (size || 5) * 0.25 }}rem"
  class="{{ classes }}"
>
  <path
    stroke-linecap="round"
    stroke-linejoin="round"
    d="M4 6h16M4 12h16M4 18h16"
  >
  </path>
</svg>
