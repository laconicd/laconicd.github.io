  xmlns="http://www.w3.org/2000/svg"
  fill="none"
  viewBox="0 0 24 24"
  stroke="currentColor"
  stroke-width="{{ stroke || 2 }}"
  width="{{ (size || 6) * 0.25 }}rem"
  height="{{ (size || 6) * 0.25 }}rem"
  class="{{ class }}"
>
  <path
    stroke-linecap="round"
    stroke-linejoin="round"
    d="M13 10V3L4 14h7v7l9-11h-7z"
  />
</svg>
