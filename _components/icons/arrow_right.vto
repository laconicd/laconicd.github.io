<svg
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
  viewBox="0 0 24 24"
  stroke="currentColor"
  stroke-width="{{ stroke || 3 }}"
  width="{{ (size || 4) * 0.25 }}rem"
  height="{{ (size || 4) * 0.25 }}rem"
  class="{{ classes }}"
>
  <path
    stroke-linecap="round"
    stroke-linejoin="round"
    d="M14 5l7 7m0 0l-7 7m7-7H3"
  />
</svg>
